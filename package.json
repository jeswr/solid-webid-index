    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "jsonld": "^9.0.0",
    "lucide-react": "^1.17.0",
    "n3": "^2.0.3",
    "next": "~15.5.19",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
